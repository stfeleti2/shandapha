{
  "name": "@shandapha/generator-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Server-side generation core used by the CLI, API, and future server actions.",
  "sideEffects": false,
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json",
    "lint": "biome check --config-path ../../../configs/biome.json src",
    "test": "vitest run"
  },
  "dependencies": {
    "@shandapha/contracts": "workspace:*",
    "@shandapha/entitlements": "workspace:*",
    "@shandapha/packs": "workspace:*",
    "@shandapha/registry-server": "workspace:*",
    "@shandapha/tokens": "workspace:*"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}

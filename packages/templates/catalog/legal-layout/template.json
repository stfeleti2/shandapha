{
  "version": 1,
  "slug": "legal-layout",
  "name": "Legal Layout",
  "group": "marketing",
  "shell": "DocsShell",
  "summary": "Legal content layout with side navigation, trust accents, and article framing.",
  "states": ["loading", "empty", "error", "success", "no access"],
  "variants": ["privacy", "terms", "security"],
  "blocks": ["legal-shell", "docs-article"],
  "related": ["docs-article", "faq"],
  "surfaces": ["docs shell", "sidebar", "article layout"],
  "featuredPackIds": ["normal", "glass"],
  "dataContract": {
    "entities": ["policySection"],
    "slots": ["sidebar", "article", "metaRail"],
    "outputs": ["policy article"],
    "samples": ["policy-sections.json"]
  },
  "frameworks": [
    {
      "adapter": "react-vite",
      "support": "supported",
      "notes": "Reference adapter and fastest path for local starters.",
      "requiredCapabilities": []
    },
    {
      "adapter": "next-app-router",
      "support": "supported",
      "notes": "Reference SSR-capable adapter for product starters.",
      "requiredCapabilities": ["server-components"]
    },
    {
      "adapter": "wc-universal",
      "support": "experimental",
      "notes": "Portable surface area is still being rebuilt around the WC baseline.",
      "requiredCapabilities": ["custom-elements"]
    },
    {
      "adapter": "blazor-wc",
      "support": "experimental",
      "notes": "Blazor currently installs through the WC bridge rather than a native adapter.",
      "requiredCapabilities": ["custom-elements", "wc-interop"]
    }
  ],
  "install": {
    "requiredPackages": [],
    "requiredRoutes": [],
    "themeDependencies": ["theme.css", "tokens.json"],
    "sampleDataBindings": ["policy-sections.json"]
  }
}

{
  "version": 1,
  "slug": "docs-home",
  "name": "Docs Home",
  "group": "docs",
  "shell": "DocsShell",
  "summary": "Documentation landing page with category rails, quickstarts, and install guidance.",
  "states": ["loading", "empty", "error", "success", "no access"],
  "variants": ["product", "developer"],
  "blocks": ["docs-home-grid", "quickstart-cards", "registry-setup"],
  "related": ["docs-article", "changelog"],
  "surfaces": ["docs shell", "cards", "search strip"],
  "featuredPackIds": ["normal", "glass"],
  "dataContract": {
    "entities": ["docCategory", "quickstart", "registryItem"],
    "slots": ["hero", "categoryGrid", "quickstarts", "registrySummary"],
    "outputs": ["docs landing"],
    "samples": ["docs-home.json"]
  },
  "frameworks": [
    {
      "adapter": "react-vite",
      "support": "supported",
      "notes": "Reference adapter and fastest path for local starters.",
      "requiredCapabilities": []
    },
    {
      "adapter": "next-app-router",
      "support": "supported",
      "notes": "Reference SSR-capable adapter for product starters.",
      "requiredCapabilities": ["server-components"]
    },
    {
      "adapter": "wc-universal",
      "support": "experimental",
      "notes": "Portable surface area is still being rebuilt around the WC baseline.",
      "requiredCapabilities": ["custom-elements"]
    },
    {
      "adapter": "blazor-wc",
      "support": "experimental",
      "notes": "Blazor currently installs through the WC bridge rather than a native adapter.",
      "requiredCapabilities": ["custom-elements", "wc-interop"]
    }
  ],
  "install": {
    "requiredPackages": [],
    "requiredRoutes": [],
    "themeDependencies": ["theme.css", "tokens.json"],
    "sampleDataBindings": ["docs-home.json"]
  }
}

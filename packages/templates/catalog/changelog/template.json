{
  "version": 1,
  "slug": "changelog",
  "name": "Changelog",
  "group": "docs",
  "shell": "DocsShell",
  "summary": "Release note stream with upgrade guidance, registry updates, and issue tracking hooks.",
  "states": ["loading", "empty", "error", "success", "no access"],
  "variants": ["product", "package"],
  "blocks": ["release-feed", "upgrade-guide", "registry-summary"],
  "related": ["docs-home", "blog-index"],
  "surfaces": ["timeline", "badge", "article cards"],
  "featuredPackIds": ["normal", "glass"],
  "dataContract": {
    "entities": ["release", "upgradeNote", "registryItem"],
    "slots": ["releaseFeed", "upgradeGuide", "registrySummary"],
    "outputs": ["changelog page"],
    "samples": ["releases.json"]
  },
  "frameworks": [
    {
      "adapter": "react-vite",
      "support": "supported",
      "notes": "Reference adapter and fastest path for local starters.",
      "requiredCapabilities": []
    },
    {
      "adapter": "next-app-router",
      "support": "supported",
      "notes": "Reference SSR-capable adapter for product starters.",
      "requiredCapabilities": ["server-components"]
    },
    {
      "adapter": "wc-universal",
      "support": "experimental",
      "notes": "Portable surface area is still being rebuilt around the WC baseline.",
      "requiredCapabilities": ["custom-elements"]
    },
    {
      "adapter": "blazor-wc",
      "support": "experimental",
      "notes": "Blazor currently installs through the WC bridge rather than a native adapter.",
      "requiredCapabilities": ["custom-elements", "wc-interop"]
    }
  ],
  "install": {
    "requiredPackages": [],
    "requiredRoutes": [],
    "themeDependencies": ["theme.css", "tokens.json"],
    "sampleDataBindings": ["releases.json"]
  }
}

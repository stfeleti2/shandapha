{
  "version": 1,
  "slug": "detail-tabs-timeline",
  "name": "Detail Tabs Timeline",
  "group": "saas",
  "shell": "SidebarShell",
  "summary": "Entity detail screen with summary card, tabs, timeline, and related activity.",
  "states": ["loading", "empty", "error", "success", "no access"],
  "variants": ["client-service", "b2b account"],
  "blocks": ["detail-overview", "activity-timeline", "related-items"],
  "related": ["list-filters", "settings-sectioned"],
  "surfaces": ["tabs", "items", "timeline rail"],
  "featuredPackIds": ["normal", "glass"],
  "dataContract": {
    "entities": ["account", "event", "relatedEntity"],
    "slots": ["summary", "tabPanels", "timeline", "relatedStrip"],
    "outputs": ["record summary", "recent events", "linked entities"],
    "samples": ["account.json", "events.json"]
  },
  "frameworks": [
    {
      "adapter": "react-vite",
      "support": "supported",
      "notes": "Reference adapter and fastest path for local starters.",
      "requiredCapabilities": []
    },
    {
      "adapter": "next-app-router",
      "support": "supported",
      "notes": "Reference SSR-capable adapter for product starters.",
      "requiredCapabilities": ["server-components"]
    },
    {
      "adapter": "wc-universal",
      "support": "experimental",
      "notes": "Portable surface area is still being rebuilt around the WC baseline.",
      "requiredCapabilities": ["custom-elements"]
    },
    {
      "adapter": "blazor-wc",
      "support": "experimental",
      "notes": "Blazor currently installs through the WC bridge rather than a native adapter.",
      "requiredCapabilities": ["custom-elements", "wc-interop"]
    }
  ],
  "install": {
    "requiredPackages": [],
    "requiredRoutes": [],
    "themeDependencies": ["theme.css", "tokens.json"],
    "sampleDataBindings": ["account.json", "events.json"]
  }
}

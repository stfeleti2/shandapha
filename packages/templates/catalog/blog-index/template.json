{
  "version": 1,
  "slug": "blog-index",
  "name": "Blog Index",
  "group": "docs",
  "shell": "MarketingShell",
  "summary": "Journal index for product updates, launch stories, and registry notes.",
  "states": ["loading", "empty", "error", "success", "no access"],
  "variants": ["product", "culture"],
  "blocks": ["article-grid", "category-pills"],
  "related": ["blog-article", "changelog"],
  "surfaces": ["cards", "filters", "empty state"],
  "featuredPackIds": ["normal", "glass", "neon"],
  "dataContract": {
    "entities": ["post", "tag"],
    "slots": ["hero", "filters", "postGrid"],
    "outputs": ["post index"],
    "samples": ["posts.json"]
  },
  "frameworks": [
    {
      "adapter": "react-vite",
      "support": "supported",
      "notes": "Reference adapter and fastest path for local starters.",
      "requiredCapabilities": []
    },
    {
      "adapter": "next-app-router",
      "support": "supported",
      "notes": "Reference SSR-capable adapter for product starters.",
      "requiredCapabilities": ["server-components"]
    },
    {
      "adapter": "wc-universal",
      "support": "experimental",
      "notes": "Portable surface area is still being rebuilt around the WC baseline.",
      "requiredCapabilities": ["custom-elements"]
    },
    {
      "adapter": "blazor-wc",
      "support": "experimental",
      "notes": "Blazor currently installs through the WC bridge rather than a native adapter.",
      "requiredCapabilities": ["custom-elements", "wc-interop"]
    }
  ],
  "install": {
    "requiredPackages": [],
    "requiredRoutes": [],
    "themeDependencies": ["theme.css", "tokens.json"],
    "sampleDataBindings": ["posts.json"]
  }
}
